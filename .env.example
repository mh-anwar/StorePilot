# Required
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
APP_ENCRYPTION_KEY=  # 32 random bytes as hex — `openssl rand -hex 32`
SESSION_SECRET=      # any random string, 32+ bytes

# Platform AI key (optional if all users will BYO-key)
ANTHROPIC_API_KEY=sk-ant-...

# Shopify app (required to use Path A: "Connect Shopify")
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Optional override — default is a sensible read/write scope set.
# SHOPIFY_SCOPES=read_products,write_products,read_orders,...
APP_URL=http://localhost:3000

# Auth/access
# Gate /chat with a shared access code. Users who BYO-key bypass this.
# ACCESS_CODE=
# Force /dashboard behind auth. Default allows the demo dashboard.
# REQUIRE_AUTH=1

# Job queue: secret required to call /api/jobs/tick from a scheduler
TICK_SECRET=
